{
  "name": "@orion/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsc -p tsconfig.build.json && corepack pnpm run --parallel \"/^dev:(compile|serve)$/\"",
    "dev:compile": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "dev:serve": "node --watch --watch-preserve-output dist/main.js",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.scripts.json",
    "test": "vitest run --fileParallelism=false",
    "db:generate": "prisma generate --config prisma.config.ts",
    "db:migrate": "prisma migrate dev --config prisma.config.ts --name add_chat_mvp",
    "db:migrate:deploy": "prisma migrate deploy --config prisma.config.ts",
    "db:bootstrap:production": "tsx prisma/bootstrap-production.ts",
    "db:seed": "prisma db seed --config prisma.config.ts",
    "db:studio": "prisma studio --config prisma.config.ts",
    "db:reset": "prisma migrate reset --config prisma.config.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.8",
    "@nestjs/core": "^11.1.8",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/platform-express": "^11.1.8",
    "@nestjs/platform-socket.io": "11.1.8",
    "@nestjs/websockets": "11.1.8",
    "@orion/shared": "workspace:*",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "bcrypt": "6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.4.2",
    "pg": "8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "4.8.1"
  },
  "devDependencies": {
    "@nestjs/testing": "11.1.8",
    "@types/bcrypt": "6.0.0",
    "@types/node": "^24.9.1",
    "@types/supertest": "^7.2.0",
    "prisma": "7.8.0",
    "supertest": "^7.2.2",
    "tsx": "^4.20.6",
    "vitest": "4.1.10"
  }
}
