{
  "name": "orion",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "dev": "corepack pnpm --parallel --filter @orion/backend --filter @orion/frontend dev",
    "build": "corepack pnpm --recursive build",
    "lint": "corepack pnpm --recursive lint",
    "typecheck": "corepack pnpm --recursive typecheck",
    "test": "corepack pnpm --recursive test",
    "db:generate": "corepack pnpm --filter @orion/backend db:generate",
    "db:migrate": "corepack pnpm --filter @orion/backend db:migrate",
    "db:migrate:deploy": "corepack pnpm --filter @orion/backend db:migrate:deploy",
    "db:bootstrap:production": "corepack pnpm --filter @orion/backend db:bootstrap:production",
    "db:seed": "corepack pnpm --filter @orion/backend db:seed",
    "db:studio": "corepack pnpm --filter @orion/backend db:studio",
    "db:reset": "corepack pnpm --filter @orion/backend db:reset",
    "deploy:config": "docker compose --env-file .env.production -f compose.production.yml config",
    "deploy:build": "docker compose --env-file .env.production -f compose.production.yml build",
    "deploy:up": "docker compose --env-file .env.production -f compose.production.yml up -d --build",
    "deploy:status": "docker compose --env-file .env.production -f compose.production.yml ps",
    "verify:deployment": "node scripts/verify-deployment.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@next/eslint-plugin-next": "^15.5.20",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4"
  }
}
