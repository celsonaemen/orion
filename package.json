{
  "name": "orion",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "dev": "corepack pnpm --parallel --filter './apps/*' dev",
    "build": "corepack pnpm --recursive build",
    "lint": "corepack pnpm --recursive lint",
    "typecheck": "corepack pnpm --recursive typecheck",
    "test": "corepack pnpm --recursive test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@next/eslint-plugin-next": "^15.5.20",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4"
  }
}
